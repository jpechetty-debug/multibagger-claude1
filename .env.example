# Copy this file to .env — never commit .env itself

# ── Data sources ──────────────────────────────────────────────────────────────
#
# yfinance (default, no key needed)
#
# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
# DATABASE_URL=sqlite:///stocks.db
#
# PostgreSQL / TimescaleDB (production):
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/multibagger_db

# ── Task queue ────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Risk governor ─────────────────────────────────────────────────────────────
VIX_KILL_SWITCH=25
MAX_SECTOR_EXPOSURE=0.30
MAX_DRAWDOWN_RATE=0.15
MAX_CORRELATION_THRESHOLD=0.80

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
