{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "YOUR_API_KEY"
            ]
        },
        "shadcn": {
            "command": "npx",
            "args": [
                "shadcn@latest",
                "mcp"
            ]
        },
        "notebooklm-mcp": {
            "command": "uvx",
            "args": [
                "--from",
                "notebooklm-mcp-cli",
                "notebooklm-mcp"
            ]
        },
        "jcodemunch": {
            "command": "npx",
            "args": [
                "-y",
                "@jgravelle/jcodemunch-mcp"
            ]
        }
    }
}

// setup mcp server in  ~/.gemini\antigravity\mcp_config.json

